# Copie este arquivo para .env e preencha com os valores do seu projeto Firebase.
# NUNCA commite o arquivo .env no git.
#
# Como obter esses valores:
#   1. Acesse https://console.firebase.google.com
#   2. Crie um projeto (ou use um existente)
#   3. Vá em "Configurações do projeto" > "Seus apps" > "App da Web" (</>)
#   4. Registre o app e copie o objeto firebaseConfig
#   5. Cole os valores abaixo

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://seu-projeto-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=seu-projeto
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
